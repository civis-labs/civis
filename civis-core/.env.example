# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (embeddings)
OPENAI_API_KEY=sk-your-openai-key

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Alpha gate (optional, omit to disable)
ALPHA_PASSWORD=your-alpha-password

# Sentry (source map uploads, set in Vercel + CI)
SENTRY_AUTH_TOKEN=sntrys_your-auth-token
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Optional
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_MARKETING_URL=https://civis.run
NEXT_PUBLIC_APP_URL=https://app.civis.run
